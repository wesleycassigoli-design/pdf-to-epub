# ─── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=replace-with-a-very-long-random-string-here

# ─── Database ──────────────────────────────────────────────────────────────
# Local (docker-compose)
DATABASE_URL=postgresql://user:password@db:5432/pdfepub

# Supabase (produção) — substitua pelo Supabase connection string
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=pdf-epub-files

# ─── Upload limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_MB=100
ALLOWED_EXTENSIONS=pdf

# ─── Celery ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ─── Output paths ──────────────────────────────────────────────────────────
OUTPUT_DIR=/app/output
TEMP_DIR=/tmp/pdfepub
